{
  "organization": {
    "default_organize_by": "type",
    "default_metadata_depth": 0,
    "extract_metadata": true
  },
  "file_categories": {
    "custom_categories": {},
    "excluded_extensions": []
  },
  "metadata": {
    "extract_images": true,
    "extract_audio": true,
    "extract_video": true,
    "extract_documents": true,
    "extract_text": true
  },
  "paths": {
    "excluded_directories": [
      "Windows",
      "Program Files",
      "Program Files (x86)",
      "ProgramData",
      "System Volume Information",
      "$Recycle.Bin",
      "Recovery",
      "AppData",
      "PerfLogs",
      "Boot",
      "Config.Msi"
    ]
  },
  "performance": {
    "batch_size": 100,
    "show_progress": true
  },
  "output": {
    "generate_metadata_report": false,
    "metadata_report_path": "metadata_report.json"
  },
  "updates": {
    "update_check_enabled": true,
    "update_check_on_startup": true,
    "auto_download": false,
    "version_url": null,
    "installer_url": null,
    "release_api_url": null,
    "check_interval_days": 1
  }
}

