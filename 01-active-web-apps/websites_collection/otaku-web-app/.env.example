# Copy to `.env.local` and fill in values.

# PostgreSQL — gamification event ledger + user_stats projection
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Yjs CRDT relay (unified-new / optional web sync)
NEXT_PUBLIC_YJS_WS_URL=wss://your-yjs-relay.example.com

# Tauri desktop build flag (dual DB mode prep)
# NEXT_PUBLIC_TARGET=desktop

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase (membership / inventory)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI (VN / assistant)
GOOGLE_GENERATIVE_AI_API_KEY=
